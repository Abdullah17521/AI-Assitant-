    {
      "parameters": {
        "jsCode": "// ── Extract & normalize all event fields ──────────────────────────────\nconst event = $input.first().json;\n\nconst rawStart = event.start?.dateTime || event.start?.date || '';\nconst rawEnd   = event.end?.dateTime   || event.end?.date   || '';\n\nconst fmt = (iso) => {\n  if (!iso) return 'N/A';\n  return new Date(iso).toLocaleString('en-US', {\n    weekday:'long', year:'numeric', month:'long',\n    day:'numeric', hour:'2-digit', minute:'2-digit', hour12:true\n  });\n};\n\nconst title       = event.summary          || 'Untitled Event';\nconst description = event.description      || '';\nconst location    = event.location         || 'Not specified';\nconst organizer   = event.organizer?.email || 'Unknown';\nconst attendees   = (event.attendees || []).map(a => a.email).join(', ') || 'None';\nconst eventLink   = event.htmlLink         || '';\nconst startFmt    = fmt(rawStart);\nconst endFmt      = fmt(rawEnd);\n\n// ── Detect event type from title keywords ─────────────────────────────\nconst t = title.toLowerCase();\nlet eventType = 'General';\nif (/meet|sync|standup|call|zoom|teams|conf/i.test(t))  eventType = 'Meeting';\nelse if (/birthday|bday|anniversary|celebrate/i.test(t)) eventType = 'Birthday';\nelse if (/deadline|submit|due|delivery|launch/i.test(t)) eventType = 'Deadline';\nelse if (/interview|hiring|recruit/i.test(t))            eventType = 'Interview';\nelse if (/holiday|vacation|leave|off|pto/i.test(t))      eventType = 'Holiday';\nelse if (/review|performance|appraisal/i.test(t))        eventType = 'Review';\nelse if (/training|workshop|seminar|webinar|course/i.test(t)) eventType = 'Training';\nelse if (/party|dinner|lunch|breakfast|event/i.test(t))  eventType = 'Social';\n\n// ── Detect urgency ────────────────────────────────────────────────────\nlet urgency = 'Normal';\nif (/urgent|asap|critical|important|priority|emergency/i.test(title + ' ' + description)) {\n  urgency = 'High';\n} else if (eventType === 'Deadline' || eventType === 'Interview') {\n  urgency = 'High';\n} else if (eventType === 'Birthday' || eventType === 'Social' || eventType === 'Holiday') {\n  urgency = 'Low';\n}\n\n// ── Detect language preference (from description or title) ────────────\nlet language = 'English';\nif (/urdu|اردو|پاکستان|آپ|ہے/i.test(title + ' ' + description)) language = 'Urdu';\n\nreturn [{\n  json: {\n    title, description, location, organizer,\n    attendees, eventLink, eventType, urgency,\n    language, startFmt, endFmt, rawStart, rawEnd\n  }\n}];"
      },
      "id": "bf684905-a3c1-4b31-99f1-23df06b4faf1",
