    {
      "parameters": {
        "jsCode": "// ── Extract AI response and finalize message ─────────────────────────\nconst groqResponse = $input.first().json;\nconst prevData     = $('Extract & Analyze Event').first().json;\n\nlet aiMessage = '';\ntry {\n  aiMessage = groqResponse.choices[0].message.content.trim();\n} catch(e) {\n  // Fallback if Groq fails\n  aiMessage = `📅 *NEW EVENT: ${prevData.title}*\\n\\n🗓 *Start:* ${prevData.startFmt}\\n🏁 *End:* ${prevData.endFmt}\\n📍 *Location:* ${prevData.location}\\n👤 *Organizer:* ${prevData.organizer}\\n\\n✅ _Added to your Google Calendar._`;\n}\n\n// Add event metadata footer\nconst footer = `\\n\\n─────────────────\\n📆 _Type: ${prevData.eventType} | Priority: ${prevData.urgency}_`;\nconst finalMessage = aiMessage + footer;\n\nreturn [{\n  json: {\n    finalMessage,\n    eventType:  prevData.eventType,\n    urgency:    prevData.urgency,\n    language:   prevData.language,\n    title:      prevData.title,\n    startFmt:   prevData.startFmt,\n    eventLink:  prevData.eventLink,\n    groqTokensUsed: groqResponse.usage?.total_tokens || 0\n  }\n}];"
      },
